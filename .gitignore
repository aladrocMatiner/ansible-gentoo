# Downloaded Gentoo release artifacts are fetched inputs, not source.
gentoo.iso/
gentoo.iso

# Local secret files must never be committed.
.env
.env.*
!.env.example
var/secrets/

# Runtime logs and temporary files.
logs/
tmp/

# Legacy local QEMU test VM artifacts.
var/qemu/*.qcow2
var/qemu/*.fd

# Local libvirt test VM artifacts.
var/libvirt/*.qcow2
var/libvirt/*.xml
var/libvirt/*-gentoo-kernel
var/libvirt/*-gentoo-initrd
var/libvirt/nvram/
logs/libvirt/

# Python bytecode generated during local validation.
__pycache__/
*.pyc
