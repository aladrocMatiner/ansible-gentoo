# Example local environment file for gentoo-ai-installer.
# Copy to .env only for local use. .env is gitignored.
# Keep secret values empty in this example file.

# Codex bootstrap may use environment-based authentication in the live ISO.
OPENAI_API_KEY=
CODEX_AUTH_TOKEN=

# Future installer workflows must not pass passwords or private keys through
# committed files. These names are documented for policy clarity only.
ADMIN_PASSWORD=
ROOT_PASSWORD=
SSH_PRIVATE_KEY=

# User configuration workflows accept paths to local gitignored files.
# Values stay empty here; do not commit real hashes, keys, or credentials.
ADMIN_PASSWORD_HASH_FILE=
ROOT_PASSWORD_HASH_FILE=
ADMIN_AUTHORIZED_KEYS_FILE=

# Optional sudo policy. Leave empty for the safe default: password-requiring sudo.
# Disposable libvirt E2E installs default this to yes through VM_E2E_ADMIN_SUDO_NOPASSWD.
ADMIN_SUDO_NOPASSWD=
