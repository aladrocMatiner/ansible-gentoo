# Example local environment file for gentoo-ai-installer.
# Copy to .env only for local use. .env is gitignored.
# Keep secret values empty in this example file.

# Codex bootstrap may use environment-based authentication in the live ISO.
OPENAI_API_KEY=
CODEX_AUTH_TOKEN=

# Future installer workflows must not pass passwords or private keys through
# committed files. These names are documented for policy clarity only.
ADMIN_PASSWORD=
ROOT_PASSWORD=
SSH_PRIVATE_KEY=
